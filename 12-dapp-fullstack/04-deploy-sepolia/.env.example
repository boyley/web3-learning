# ================= 合约端环境变量示例 =================
# 用法：把本文件复制为 .env 并填入你自己的值。
#   cp .env.example .env
# ⚠️ .env 已被 .gitignore 忽略，绝不会提交到仓库。绝不要把真实私钥贴给任何人！

# Sepolia 测试网 RPC 节点地址（从 Alchemy / Infura 免费申请一个）
# 例如： https://eth-sepolia.g.alchemy.com/v2/你的KEY
SEPOLIA_RPC_URL="https://eth-sepolia.g.alchemy.com/v2/YOUR_ALCHEMY_KEY"

# 部署用账户的私钥（十六进制，不带 0x 也可）。
# ⚠️ 强烈建议：专门新建一个「测试用小号钱包」，里面只放少量测试币，绝不用日常主力钱包！
PRIVATE_KEY="0xYOUR_TEST_WALLET_PRIVATE_KEY"

# Etherscan API Key（做合约验证用，https://etherscan.io/myapikey 免费申请）
ETHERSCAN_API_KEY="YOUR_ETHERSCAN_API_KEY"
