// SPDX-License-Identifier: MIT
pragma solidity ^0.8.20;

// ============================================================
// HelloSolidity —— 你的第一个 Solidity 合约
// 教学用途，未经审计，勿直接上主网。
// ============================================================
//
// 本文件聚焦以下知识点：
//   1. SPDX 许可证标识（第 1 行）
//   2. pragma 版本约束（第 2 行的 ^ 含义）
//   3. contract 关键字：合约就像一个部署在链上的「对象」
//   4. 状态变量（state variable）：数据永久存在链上
//   5. 读函数 / 写函数：如何改数据、如何取数据
//
// ------------------------------------------------------------
// 【第 1 行】SPDX-License-Identifier
//   - SPDX 是「软件包数据交换」的开源许可证标准写法。
//   - Solidity 编译器建议每个源文件顶部声明许可证，否则编译时会给出 warning。
//   - MIT 是最宽松的开源许可证之一；教学项目常用 MIT。
//   - 这只是一段注释元信息，不产生任何字节码，纯粹是给人和工具看的。
//
// 【第 2 行】pragma solidity ^0.8.20;
//   - pragma 用来约束「用哪个版本的编译器来编译本文件」，防止版本不兼容。
//   - ^0.8.20 的含义：允许 >=0.8.20 且 <0.9.0 的编译器。
//       · ^ 锁住最左边非零的版本号（这里是次版本 8），
//         所以主版本必须是 0、次版本必须是 8，补丁号 >=20 均可。
//       · 即 0.8.20、0.8.25、0.8.35 都能编译，但 0.9.0 不行。
//   - 为什么用 0.8.x？从 0.8.0 起，算术运算默认带溢出检查（overflow/underflow 会 revert），
//     更安全，是当前主流版本线；官方当前最新为 0.8.35。
// ------------------------------------------------------------

// contract 关键字声明一个合约；HelloSolidity 是合约名（习惯用大驼峰 PascalCase）
contract HelloSolidity {
    // -------------------- 状态变量 --------------------
    // greeting 是一个「状态变量」：它的值会被永久保存在区块链存储（storage）中。
    //   - string   : 字符串类型（UTF-8 编码的动态字节序列）
    //   - public   : 可见性修饰符。声明为 public 后，编译器会「自动」为它生成一个
    //                同名的 getter 函数 greeting()，外部无需我们手写就能读取它。
    // 我们给它一个初始值，部署时就会写入这个默认问候语。
    string public greeting = "Hello, Solidity!";

    // -------------------- 写函数：修改状态 --------------------
    // setGreeting 接收一个新的问候语，并写入状态变量 greeting。
    //   - 入参 _newGreeting 用下划线前缀，是社区常见的「函数参数」命名习惯，
    //     用来和状态变量区分（非强制）。
    //   - memory：字符串是引用类型，作为函数参数时必须标注数据位置，
    //     这里用 memory 表示「仅在本次调用期间临时存在于内存」。
    //   - public：任何人都能调用这个函数。
    // 注意：这是一笔「交易（transaction）」，会修改链上状态，因此需要花费 gas。
    function setGreeting(string memory _newGreeting) public {
        greeting = _newGreeting;
    }

    // -------------------- 读函数：读取状态 --------------------
    // getGreeting 返回当前的问候语。
    //   - view      : 表示本函数只「读」状态、不「改」状态。
    //   - returns (string memory) : 声明返回值类型；字符串返回也要标注 memory。
    // 因为 greeting 本身是 public，其实已经有自动 getter 了；
    // 这里再手写一个 getGreeting，是为了直观演示「读函数」的写法。
    // 只读调用（call）不上链、不花 gas（在 Remix VM 里点它会直接显示返回值）。
    function getGreeting() public view returns (string memory) {
        return greeting;
    }
}
